# ── Qwen via DashScope (Alibaba Cloud Model Studio) ──────────────────────────
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# ── Alibaba Cloud OSS ────────────────────────────────────────────────────────
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_ENDPOINT=https://oss-ap-southeast-1.aliyuncs.com
OSS_BUCKET=ghamazon-manuscripts

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM=GHAMAZON <noreply@ghamazon.com>

# ── Promotion — hand the generated ad to your YouTube/TikTok posting bot ──────
# Your bot's endpoint. Autopilot POSTs JSON: {book_id, title, buy_url, cover_url,
# ad:{hook, script, youtube_title, description, hashtags[]}}. Empty = step skipped.
PROMO_WEBHOOK_URL=

# ── App ──────────────────────────────────────────────────────────────────────
APP_URL=https://ghamazon.pages.dev
CORS_ORIGINS=http://localhost:5173,https://ghamazon.pages.dev
